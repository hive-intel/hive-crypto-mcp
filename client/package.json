{
  "name": "hive-mcp-client",
  "version": "0.1.5",
  "description": "Typed client adapter for Hive Intelligence MCP root discovery, metadata, schema lookup, and endpoint invocation.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hive-intel/hive-sdk.git",
    "directory": "client"
  },
  "homepage": "https://github.com/hive-intel/hive-sdk/tree/main/client#readme",
  "bugs": {
    "url": "https://github.com/hive-intel/hive-sdk/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hive-intelligence",
    "crypto",
    "crypto-data",
    "ai-agents",
    "typescript",
    "adapter"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "hive-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./b2b": {
      "types": "./dist/b2b.d.ts",
      "import": "./dist/b2b.js",
      "default": "./dist/b2b.js"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk.d.ts",
      "import": "./dist/ai-sdk.js",
      "default": "./dist/ai-sdk.js"
    },
    "./langchain": {
      "types": "./dist/langchain.d.ts",
      "import": "./dist/langchain.js",
      "default": "./dist/langchain.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^1.1.36",
    "@types/node": "^22.0.0",
    "tsup": "8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}

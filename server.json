{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "xyz.hiveintelligence/mcp",
  "description": "Crypto intelligence MCP for market data, DeFi, wallets, security, DEX, NFTs, and Solana.",
  "version": "1.1.4",
  "repository": {
    "url": "https://github.com/hive-intel/hive-sdk",
    "source": "github"
  },
  "websiteUrl": "https://hiveintelligence.xyz",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.hiveintelligence.xyz/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Hive API key as a Bearer token.",
          "isRequired": true,
          "isSecret": true,
          "placeholder": "Bearer hive_your_api_key"
        }
      ]
    }
  ]
}
